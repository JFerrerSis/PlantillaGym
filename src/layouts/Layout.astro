---
interface Props {
	title?: string;
}

const { title = "IRON GYM | Entrena al Siguiente Nivel" } = Astro.props;
---

<!doctype html>
<html lang="es" class="scroll-smooth">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <meta name="description" content="No vendemos excusas, construimos disciplina. Entrena con equipamiento premium y coachs de élite." />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
    </head>
    <body class="bg-bg-main text-gray-100 font-sans antialiased overflow-x-hidden">
        <slot />
    </body>
</html>

<style is:global>
	/* Importación base de Tailwind v4 y definición del tema */
	@import "tailwindcss";

	@theme {
		/* Paleta oscura y grisácea profunda */
		--color-bg-main: #0a0a0c;
		--color-bg-card: #121216;
		--color-bg-hover: #1c1c24;
		
		/* Textos secundarios */
		--color-text-muted: #94a3b8;
		
		/* Rojo deportivo y neón de alto impacto */
		--color-brand-red: #e11d48;
		--color-brand-red-bright: #ff335c;
		--color-brand-red-dim: #4c111e;
	}

	@layer base {
		/* Personalización de la barra de scroll estilo gaming/premium */
		::-webkit-scrollbar {
			width: 8px;
		}
		::-webkit-scrollbar-track {
			background: var(--color-bg-main);
		}
		::-webkit-scrollbar-thumb {
			background: var(--color-bg-hover);
			border-radius: 4px;
		}
		::-webkit-scrollbar-thumb:hover {
			background: var(--color-brand-red);
		}

		/* Estilo de selección de texto */
		::selection {
			background-color: var(--color-brand-red-dim);
			color: #ffffff;
		}
	}
</style>